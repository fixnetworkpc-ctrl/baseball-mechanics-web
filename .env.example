# Copy this to .env.local — same Supabase project + backend as the mobile app.
# Values below are the same ones already used as EXPO_PUBLIC_* in
# baseball-mechanics-app/.env (the anon key is safe to expose client-side —
# access control is enforced by Supabase RLS, not by keeping this secret).

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_BACKEND_URL=https://baseball-mechanics-server.onrender.com
